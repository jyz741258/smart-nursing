FLASK_APP=run.py
FLASK_ENV=development
SECRET_KEY=smart-nursing-secret-key-2024
JWT_SECRET_KEY=jwt-secret-key-2024
DATABASE_URL=sqlite:///smart_nursing.db
REDIS_HOST=localhost
REDIS_PORT=6379

# ==================== 讯飞星火AI配置 ====================
XFYUN_APPID=your_appid
XFYUN_API_KEY=your_api_key
XFYUN_API_SECRET=your_api_secret
XFYUN_HTTP_PASSWORD=your_http_password

# ==================== 邮件发送配置 ====================
# QQ邮箱 SMTP 服务器地址
MAIL_SERVER=smtp.qq.com

# 建议使用 SSL 端口 465，或者使用 STARTTLS 端口 587
MAIL_PORT=465

# 是否使用 SSL（推荐使用 SSL，端口 465）
# 如果使用 587 端口，请将此配置设为 False，并启用 MAIL_USE_TLS
MAIL_USE_SSL=True

# 是否使用 STARTTLS（用于端口 587）
MAIL_USE_TLS=False

# 邮箱用户名（你的QQ邮箱）
MAIL_USERNAME=your_email@qq.com

# 邮箱密码（QQ邮箱需要使用授权码，不是登录密码）
# 在 QQ 邮箱设置 -> 账户 -> POP3/SMTP服务 中生成授权码
MAIL_PASSWORD=your授权码

# 发件人显示名称
MAIL_DEFAULT_SENDER=智慧养老系统 <your_email@qq.com>

# ==================== 支付宝沙箱配置 ====================
# 1. 沙箱 APPID
ALIPAY_APP_ID=2021000122600000

# 2. 应用私钥（PKCS8格式）
ALIPAY_PRIVATE_KEY=-----BEGIN PRIVATE KEY-----
your_private_key_here
-----END PRIVATE KEY-----

# 3. 支付宝公钥
ALIPAY_PUBLIC_KEY=-----BEGIN PUBLIC KEY-----
your_public_key_here
-----END PUBLIC KEY-----

# 4. 沙箱网关
ALIPAY_GATEWAY=https://openapi-sandbox.dl.alipaydev.com/gateway.do

# 5. 回调地址（沙箱环境使用localhost）
ALIPAY_NOTIFY_URL=http://localhost:5000/api/payment/notify
ALIPAY_RETURN_URL=http://localhost:3000/payment/result

# ==================== 微信支付配置 ====================
# 微信应用ID
WECHAT_APP_ID=wx1234567890abcdef

# 微信商户号
WECHAT_MCH_ID=1234567890

# 微信API密钥（32位）
WECHAT_API_KEY=your_api_key_here

# 微信支付证书路径（退款时需要）
WECHAT_CERT_PATH=cert/apiclient_cert.pem
WECHAT_KEY_PATH=cert/apiclient_key.pem

# ==================== 通用配置 ====================
# 前端地址（用于支付回调跳转）
FRONTEND_URL=http://localhost:3000

# 是否启用沙箱环境（生产环境设为false）
SANDBOX_MODE=true
