### API 请求封装
```typescript
// frontend/src/utils/request.ts
import { useUserStore } from '@/stores/user'

export const request = (options: UniApp.RequestOptions) => {
  const userStore = useUserStore()
  const token = userStore.token

  return new Promise((resolve, reject) => {
    uni.request({
      ...options,
      header: {
        'Content-Type': 'application/json',
        'Authorization': token ? `Bearer ${token}` : '',
        ...options.header
      },
      success: (res) => {
        if (res.statusCode === 200) {
          resolve(res.data)
        } else if (res.statusCode === 401) {
          userStore.logout()
          uni.reLaunch({ url: '/pages/login/index' })
        } else {
          reject(res.data)
        }
      },
      fail: reject
    })
  })
}
```

### Pinia Store 示例
```typescript
// frontend/src/stores/elder.ts
import { defineStore } from 'pinia'
import { ref } from 'vue'
import { request } from '@/utils/request'

export const useElderStore = defineStore('elder', () => {
  const elders = ref([])
  const currentElder = ref(null)

  const fetchElders = async (params?: any) => {
    const res = await request({
      url: '/api/v1/elders',
      method: 'GET',
      data: params
    })
    elders.value = res.data.items
  }

  const setCurrentElder = (elder: any) => {
    currentElder.value = elder
  }

  return {
    elders,
    currentElder,
    fetchElders,
    setCurrentElder
  }
})
```

## 后端开发规范

### Flask Blueprint 结构
```python
# backend/app/api/elders.py
from flask import Blueprint, request, jsonify
from flask_jwt_extended import jwt_required, get_jwt_identity
from app.models.elder import Elder
from app.models.user import User
from app import db

bp = Blueprint('elders', __name__, url_prefix='/api/v1/elders')

@bp.route('', methods=['GET'])
@jwt_required()
def get_elders():
    """获取老人列表（支持分页、筛选）"""
    current_user_id = get_jwt_identity()
    user = User.query.get(current_user_id)

    query = Elder.query.filter_by(deleted_at=None)

    # 权限过滤
    if user.role == 'nurse':
        query = query.filter_by(area_id=user.area_id)
    elif user.role == 'family':
        query = query.filter_by(family_id=user.id)

    page = request.args.get('page', 1, type=int)
    per_page = request.args.get('page_size', 20, type=int)

    pagination = query.paginate(page=page, per_page=per_page)

    return jsonify({
        'code': 200,
        'message': 'success',
        'data': {
            'items': [e.to_dict() for e in pagination.items],
            'total': pagination.total,
            'page': page,
            'page_size': per_page,
            'total_pages': pagination.pages
        }
    })
```

### SQLAlchemy 模型示例
```python
# backend/app/models/elder.py
from datetime import datetime
from app import db

class Elder(db.Model):
    __tablename__ = 'elders'

    id = db.Column(db.Integer, primary_key=True)
    name = db.Column(db.String(50), nullable=False)
    gender = db.Column(db.Enum('male', 'female', 'other'), default='other')
    birthday = db.Column(db.Date, nullable=False)
    id_card = db.Column(db.String(18), unique=True, nullable=False)
    phone = db.Column(db.String(11), unique=True)
    emergency_contact = db.Column(db.String(50))
    emergency_phone = db.Column(db.String(11))
    area_id = db.Column(db.Integer, db.ForeignKey('areas.id'))
    status = db.Column(db.Enum('active', 'inactive', 'emergency'), default='active')
    created_at = db.Column(db.DateTime, default=datetime.utcnow)
    updated_at = db.Column(db.DateTime, default=datetime.utcnow, onupdate=datetime.utcnow)
    deleted_at = db.Column(db.DateTime, nullable=True)

    # 关系
    health_records = db.relationship('HealthRecord', backref='elder', lazy=True)
    medication_reminders = db.relationship('MedicationReminder', backref='elder', lazy=True)

    def to_dict(self, include_sensitive=False):
        """序列化，根据角色脱敏"""
        data = {
            'id': self.id,
            'name': self.name,
            'gender': self.gender,
            'birthday': self.birthday.strftime('%Y-%m-%d') if self.birthday else None,
            'status': self.status,
            'area_id': self.area_id,
            'created_at': self.created_at.isoformat() if self.created_at else None
        }

        if include_sensitive:
            data.update({
                'id_card': self.id_card,
                'phone': self.phone,
                'emergency_contact': self.emergency_contact,
                'emergency_phone': self.emergency_phone
            })
        else:
            # 脱敏处理
            data.update({
                'id_card': self.id_card[:6] + '********' + self.id_card[-4:] if self.id_card else None,
                'phone': self.phone[:3] + '****' + self.phone[-4:] if self.phone else None
            })

        return data
```

### 认证装饰器（带权限校验）
```python
# backend/app/decorators.py
from functools import wraps
from flask_jwt_extended import verify_jwt_in_request, get_jwt_identity
from app.models.user import User

def role_required(roles):
    """角色权限装饰器"""
    def decorator(fn):
        @wraps(fn)
        def wrapper(*args, **kwargs):
            verify_jwt_in_request()
            current_user_id = get_jwt_identity()
            user = User.query.get(current_user_id)

            if not user or user.role not in roles:
                return jsonify({'code': 403, 'message': '权限不足'}), 403

            return fn(*args, **kwargs)
        return wrapper
    return decorator

# 使用示例
@bp.route('', methods=['GET'])
@jwt_required()
@role_required(['admin', 'nurse', 'family'])
def get_elders():
    # 只有admin/nurse/family角色可以访问
    pass
```

## 安全要求

### 1. JWT 认证
- 所有 `/api/v1/*` 端点必须 `@jwt_required()`
- Token 有效期：7天（可配置）
- 刷新机制：`/api/v1/auth/refresh`

### 2. 数据脱敏
- 老人身份证、手机号对非管理员角色脱敏
- 家属只能看到绑定老人的完整信息

### 3. SQL 注入防护
- 必须使用 SQLAlchemy ORM 或参数化查询
- 禁止字符串拼接 SQL

### 4. XSS 防护
- 前端渲染自动转义（Vue 默认）
- 用户输入使用 `v-html` 时需谨慎

### 5. CSRF 防护
- 移动端使用 JWT，无需 CSRF token
- 管理后台（如有）需启用 CSRF

## 性能优化

### 前端
1. **列表分页**：默认 20 条/页，后端分页
2. **图片懒加载**：`<image lazy-load>`（uni-app 内置）
3. **虚拟列表**：长列表使用 `recycle-view` 组件
4. **请求防抖**：搜索框输入防抖（300ms）

### 后端
1. **数据库索引**：
   - `elders.id_card`（唯一索引）
   - `health_records.elder_id + measured_at`（联合索引）
   - `medication_reminders.next_remind_at`（定时任务查询）
2. **缓存策略**：
   - Redis 缓存老人列表（10分钟）
   - 健康数据近期热数据缓存
3. **分页查询**：禁止 `SELECT *`，使用 `limit/offset`
4. **连接池**：SQLAlchemy 配置 `pool_size=20`

## 实时推送（WebSocket）

### 连接建立
```javascript
// 前端
const socket = uni.connectSocket({
  url: 'wss://your-domain.com/ws',
  success: () => console.log('WebSocket连接成功')
})

socket.onMessage((res) => {
  const data = JSON.parse(res.data)
  if (data.type === 'emergency') {
    // 显示紧急呼叫弹窗
    uni.showModal({
      title: '紧急呼叫',
      content: data.message,
      showCancel: false
    })
  }
})
```

### 后端事件
- 老人一键呼叫 → 推送给管辖护士
- 设备异常告警 → 推送给相关护士
- 用药提醒 → 推送给老人端

## 错误处理

### 前端统一错误处理
```typescript
// utils/request.ts 中添加
interceptors.response.use(
  (response) => response,
  (error) => {
    const { status, data } = error.response || {}
    if (status === 401) {
      // token失效，跳转登录
      userStore.logout()
      uni.reLaunch({ url: '/pages/login/index' })
    } else if (status === 403) {
      uni.showToast({ title: '权限不足', icon: 'none' })
    } else {
      uni.showToast({ title: data?.message || '请求失败', icon: 'none' })
    }
    return Promise.reject(error)
  }
)
```

### 后端统一错误处理器
```python
# backend/app/errors.py
from flask import jsonify

def register_error_handlers(app):
    @app.errorhandler(404)
    def not_found(error):
        return jsonify({'code': 404, 'message': '资源不存在'}), 404

    @app.errorhandler(500)
    def internal_error(error):
        db.session.rollback()
        return jsonify({'code': 500, 'message': '服务器内部错误'}), 500
```

